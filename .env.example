# =============================================================================
# أذان — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# =============================================================================

# بيئة التشغيل (development | production | test)
NODE_ENV=development

# المنفذ الذي يعمل عليه الخادم (اختياري، الافتراضي 3000)
# PORT=3000

# مفتاح API لخدمة خارجية (مثال فقط — غير مطلوب حالياً)
# API_SECRET_KEY=

# الحد الأقصى للطلبات في الدقيقة لكل IP (اختياري، الافتراضي 60)
# RATE_LIMIT_MAX=60

# النطاقات المسموح بها CORS (مفصولة بفواصل)
# ALLOWED_ORIGINS=http://localhost:3000,https://athanapp.com
